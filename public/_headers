# Cloudflare Pages headers
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: interest-cohort=()
  # Isolates the top-level browsing context from cross-origin windows (XS-Leak hardening).
  # NOTE: deliberately NOT adding Cross-Origin-Embedder-Policy: require-corp - it would block the
  # cross-origin resources this site legitimately embeds (the Turnstile widget from
  # challenges.cloudflare.com, and the Product Hunt / Peerlist / Launchpadly badge images), for no
  # benefit (the site uses no SharedArrayBuffer / WASM threads / cross-origin isolation).
  Cross-Origin-Opener-Policy: same-origin
  # CSP in REPORT-ONLY: measures violations without blocking, so it can't break the site. Sources
  # reflect what the site actually loads (self, the Turnstile widget, and the launch-badge image
  # hosts). To enforce later, add nonces/hashes to the Astro inline scripts, drop 'unsafe-inline'
  # from script-src, then rename this header to Content-Security-Policy.
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://api.producthunt.com https://peerlist.io https://launchpadly.co https://challenges.cloudflare.com; font-src 'self'; connect-src 'self' https://challenges.cloudflare.com; frame-src 'self' https://challenges.cloudflare.com; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests

# Immutable, content-hashed build assets
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=604800

/*.png
  Cache-Control: public, max-age=604800
