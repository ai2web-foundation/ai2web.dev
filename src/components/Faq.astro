---
const faqs = [
  {
    q: "Is AI2Web just “the MCP for websites”?",
    a: "No. AI2Web is the interoperability layer above the protocols. You describe your site once as a capability model, and it projects to MCP, ACP, AP2, NLWeb, REST, GraphQL, OpenAPI and feeds, plus the discovery, validation and governance those specs intentionally leave out.",
  },
  {
    q: "Do I have to rebuild for every AI assistant?",
    a: "No. You publish one manifest at /ai2w. AI2Web speaks whichever protocol an assistant understands, so the same description works across Claude, ChatGPT and any MCP client without per-vendor work.",
  },
  {
    q: "Is it open, and what does it cost?",
    a: "It is free and open. The protocol and specification are CC-BY 4.0 and the reference SDKs are MIT licensed. There is no lock-in and no vendor needs to adopt ai2w first.",
  },
  {
    q: "How do agents discover my site?",
    a: "Through a required /.well-known/ai2w anchor that carries or points to your /ai2w manifest. The SDKs also emit /llms.txt and /.well-known/agent.json projections, so agents that speak those formats work too.",
  },
  {
    q: "Is it safe to let agents take actions?",
    a: "Yes, by construction. High-risk actions preview before they run (even if a manifest tries to declare otherwise), consent and OAuth2 + PKCE are first-class, credentials are never sent cross-origin, and every outbound request passes an SSRF guard.",
  },
  {
    q: "Which languages and platforms are supported?",
    a: "SDKs in TypeScript, JavaScript, React, Python, PHP, Go, .NET and Ruby, plus a WordPress plugin and a Chrome extension. They all produce the same manifest and score identically.",
  },
];

const jsonld = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<section class="section" id="faq">
  <div class="wrap faq">
    <div class="faq__head">
      <span class="eyebrow reveal" data-n="//">FAQ</span>
      <h2 class="h2 reveal" data-d="1">Questions,<br /><span class="dim">answered.</span></h2>
      <p class="dim reveal" data-d="2" style="margin-top:14px;font-size:.95rem">
        More in the <a href="/docs">docs</a> and the{" "}
        <a href="https://github.com/ai2web-foundation/ai2web-spec" target="_blank" rel="noopener">spec</a>.
      </p>
    </div>
    <div class="faq__list reveal" data-d="1">
      {faqs.map((f) => (
        <details class="faq__item">
          <summary class="faq__q">
            <span>{f.q}</span>
            <svg class="faq__chev" viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <p class="faq__a dim">{f.a}</p>
        </details>
      ))}
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />

  <style>
    .faq { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: clamp(28px, 5vw, 72px); align-items: start; }
    .faq__head { position: sticky; top: 90px; }
    .faq__head a { color: var(--accent); }
    .faq__list { display: grid; gap: 0; }
    .faq__item { border-bottom: 1px solid var(--line); }
    .faq__item:first-child { border-top: 1px solid var(--line); }
    .faq__q {
      display: flex; align-items: center; justify-content: space-between; gap: 16px;
      padding: 20px 4px; cursor: pointer; list-style: none;
      font-size: clamp(1rem, 1.6vw, 1.12rem); font-weight: 500; letter-spacing: -0.01em;
      transition: color .15s ease;
    }
    .faq__q::-webkit-details-marker { display: none; }
    .faq__q:hover { color: var(--accent-bright); }
    .faq__chev { flex: 0 0 auto; color: var(--text-faint); transition: transform .25s ease, color .15s ease; }
    .faq__item[open] .faq__chev { transform: rotate(180deg); color: var(--accent); }
    .faq__a { padding: 0 40px 22px 4px; line-height: 1.65; font-size: 0.96rem; max-width: 60ch; }

    @media (max-width: 820px) {
      .faq { grid-template-columns: 1fr; gap: 20px; }
      .faq__head { position: static; }
    }
  </style>
</section>
