---
import { NAV, SITE } from "../data/site";
const year = 2026;
---

<footer class="ft">
  <div class="wrap ft__in">
    <div class="ft__top">
      <div class="ft__brand">
        <img src="/ai2web-logo-white.svg" alt="AI2Web" width="120" height="30" class="ft__logo" />
        <p class="ft__tag dim">{SITE.tagline}</p>
        <div class="ft__social">
          <a class="ft__soc" href={SITE.xUrl} target="_blank" rel="noopener" aria-label="AI2Web on X">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a class="ft__soc" href={SITE.ghUrl} target="_blank" rel="noopener" aria-label="AI2Web on GitHub">
            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>
          </a>
        </div>
      </div>
      <nav class="ft__cols" aria-label="Footer">
        <div>
          <h4 class="ft__h mono">Product</h4>
          <a href="/">Overview</a>
          <a href="/docs">Docs</a>
          <a href="/validator">Validator</a>
        </div>
        <div>
          <h4 class="ft__h mono">Protocol</h4>
          <a href="https://github.com/ai2web-foundation/ai2web-spec" target="_blank" rel="noopener">Specification</a>
          <a href="https://github.com/ai2web-foundation/ai2web-spec/tree/main/rfcs" target="_blank" rel="noopener">RFCs</a>
          <a href="/docs#capabilities">Capability model</a>
        </div>
        <div>
          <h4 class="ft__h mono">More</h4>
          <a href={`mailto:${SITE.email}`}>Contact</a>
          <a href="/privacy">Privacy Policy</a>
          <a href={SITE.xUrl} target="_blank" rel="noopener">X / Twitter</a>
          <a href="https://rolandfarkas.com" target="_blank" rel="noopener">Roland Farkas</a>
        </div>
      </nav>
    </div>

    <hr class="rule" />

    <div class="ft__legal">
      <span class="dim">AI2Web Foundation · spec CC-BY 4.0 · code MIT · &copy; {year}</span>
      <button class="ft__theme" data-theme-toggle type="button">Toggle theme</button>
    </div>
  </div>

  <div class="ft__mark" aria-hidden="true">AI2WEB</div>
</footer>

<style>
  .ft { position: relative; z-index: 1; border-top: 1px solid var(--line); margin-top: 40px; overflow: hidden; }
  .ft__in { padding-block: clamp(48px, 7vw, 80px) 0; position: relative; z-index: 2; }
  .ft__top { display: grid; grid-template-columns: 1.3fr 2fr; gap: 48px; }
  .ft__logo { height: 26px; width: auto; }
  :root[data-theme="light"] .ft__logo, :root[data-theme="light"] .ft__mark { filter: invert(1); }
  .ft__tag { margin-top: 16px; max-width: 30ch; font-size: 0.92rem; }
  .ft__social { display: flex; gap: 8px; margin-top: 18px; }
  .ft__soc { display: inline-grid; place-items: center; width: 34px; height: 34px; border-radius: var(--r-sm); background: var(--surface-2); border: 1px solid var(--line); color: var(--text-dim); transition: color .15s ease, border-color .15s ease; }
  .ft__soc:hover { color: var(--text); border-color: var(--line-2); }
  .ft__cols { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
  .ft__cols > div { display: grid; gap: 10px; align-content: start; }
  .ft__h { font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-faint); margin-bottom: 2px; }
  .ft__cols a { color: var(--text-dim); font-size: 0.92rem; width: fit-content; transition: color .15s ease; }
  .ft__cols a:hover { color: var(--accent); }

  .ft .rule { margin-block: 44px 0; }
  .ft__legal { display: flex; justify-content: space-between; align-items: center; gap: 16px; padding-block: 22px 30px; flex-wrap: wrap; font-size: 0.85rem; }
  .ft__theme { background: none; border: 0; color: var(--text-faint); cursor: pointer; font: inherit; }
  .ft__theme:hover { color: var(--text); }

  .ft__mark {
    position: absolute; left: 50%; bottom: -0.22em; transform: translateX(-50%);
    font-family: var(--mono); font-weight: 700; letter-spacing: -0.02em;
    font-size: clamp(4rem, 20vw, 15rem); line-height: 0.8;
    color: transparent;
    background: linear-gradient(180deg, var(--line-2), transparent 78%);
    -webkit-background-clip: text; background-clip: text;
    pointer-events: none; user-select: none; white-space: nowrap; z-index: 1;
    opacity: 0.7;
  }

  @media (max-width: 780px) {
    .ft__top { grid-template-columns: 1fr; gap: 34px; }
    .ft__cols { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 480px) {
    .ft__cols { grid-template-columns: 1fr 1fr; }
  }
</style>
