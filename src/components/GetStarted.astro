---
import { CHROME_EXT, CHANNELS } from "../data/site";
---

<section class="section" id="get-started">
  <div class="wrap">
    <span class="eyebrow reveal" data-n="//">Get started</span>
    <h2 class="h2 reveal" data-d="1" style="margin-top:14px;max-width:18ch">Install it your way.</h2>
    <p class="lede reveal" data-d="2" style="margin-top:14px">
      A browser extension to check any site instantly, plus a native SDK in every major ecosystem.
    </p>

    <!-- Featured: Chrome extension -->
    <a class="gs-ext card reveal" data-d="2" href={CHROME_EXT.href} target="_blank" rel="noopener">
      <div class="gs-ext__glow" aria-hidden="true"></div>
      <div class="gs-ext__icon" aria-hidden="true">
        <svg viewBox="0 0 48 48" width="34" height="34"><circle cx="24" cy="24" r="21" fill="none" stroke="currentColor" stroke-width="2.2"/><circle cx="24" cy="24" r="8" fill="none" stroke="currentColor" stroke-width="2.2"/><path d="M24 16h18M15.4 20 6.6 12M24 32 15 47.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
      </div>
      <div class="gs-ext__body">
        <span class="gs-ext__tag mono">Chrome extension</span>
        <strong class="gs-ext__name">{CHROME_EXT.name}</strong>
        <span class="dim gs-ext__blurb">{CHROME_EXT.blurb}</span>
      </div>
      <span class="gs-ext__cta btn btn--primary">Add to Chrome</span>
    </a>

    <!-- SDK channels -->
    <div class="gs-grid">
      {CHANNELS.map((c, i) => (
        <div class="gs-card card reveal" data-d={String((i % 4) + 1)}>
          <a class="gs-card__head" href={c.href} target="_blank" rel="noopener">
            <span class={`gs-badge gs-badge--${c.badge.replace(/[^a-z0-9]/gi, "").toLowerCase()} mono`}>{c.badge}</span>
            <span class="gs-card__name">{c.name}</span>
            <span class="gs-card__pkg mono dim">{c.pkg}</span>
            <svg class="gs-card__arrow" viewBox="0 0 24 24" width="15" height="15" fill="none" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <button class="gs-cmd" type="button" data-copy-cmd={c.cmd} aria-label={`Copy: ${c.cmd}`}>
            <code class="mono">{c.cmd}</code>
            <svg class="gs-cmd__i" viewBox="0 0 24 24" width="14" height="14" fill="none" aria-hidden="true"><rect x="9" y="9" width="11" height="11" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M5 15V5a2 2 0 0 1 2-2h10" stroke="currentColor" stroke-width="1.6"/></svg>
          </button>
        </div>
      ))}
    </div>
  </div>

  <style>
    .gs-ext {
      position: relative; overflow: hidden; margin-top: 36px;
      display: flex; align-items: center; gap: 20px; padding: 22px 24px;
      transition: border-color .2s ease, transform .2s ease;
    }
    .gs-ext:hover { border-color: var(--line-2); transform: translateY(-2px); }
    .gs-ext__glow { position: absolute; inset: -60% 40% auto -10%; height: 220px; background: radial-gradient(50% 100% at 30% 30%, var(--accent-glow), transparent 70%); pointer-events: none; }
    .gs-ext__icon { position: relative; flex: 0 0 auto; width: 62px; height: 62px; display: grid; place-items: center; border-radius: 14px; background: var(--accent-glow); color: var(--accent-bright); }
    .gs-ext__body { position: relative; display: grid; gap: 3px; margin-right: auto; min-width: 0; }
    .gs-ext__tag { font-size: 0.7rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--text-faint); }
    .gs-ext__name { font-size: 1.16rem; font-weight: 600; letter-spacing: -0.02em; }
    .gs-ext__blurb { font-size: 0.92rem; }
    .gs-ext__cta { position: relative; flex: 0 0 auto; }

    .gs-grid { margin-top: 16px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
    .gs-card { padding: 16px 18px; display: grid; gap: 12px; align-content: start; transition: border-color .2s ease, transform .2s ease; }
    .gs-card:hover { border-color: var(--line-2); transform: translateY(-2px); }
    .gs-card__head { display: flex; align-items: center; gap: 10px; }
    .gs-badge {
      flex: 0 0 auto; display: grid; place-items: center; min-width: 34px; height: 26px; padding: 0 7px;
      border-radius: 7px; font-size: 0.72rem; font-weight: 600; letter-spacing: -0.01em;
      background: var(--surface-2); border: 1px solid var(--line); color: var(--text-dim);
    }
    .gs-badge--npm { background: rgba(203,56,55,0.14); border-color: rgba(203,56,55,0.3); color: #e06c6b; }
    .gs-badge--py  { background: rgba(255,212,59,0.12); border-color: rgba(255,212,59,0.28); color: #e3b341; }
    .gs-badge--php { background: rgba(121,134,203,0.14); border-color: rgba(121,134,203,0.3); color: #9aa7e0; }
    .gs-badge--c   { background: rgba(104,33,122,0.18); border-color: rgba(150,80,170,0.35); color: #c58fd6; }
    .gs-badge--go  { background: rgba(0,173,216,0.14); border-color: rgba(0,173,216,0.3); color: #4fd0ee; }
    .gs-badge--wp  { background: rgba(33,117,155,0.16); border-color: rgba(33,117,155,0.34); color: #58b0d6; }
    .gs-card__name { font-weight: 600; font-size: 0.98rem; }
    .gs-card__pkg { font-size: 0.78rem; margin-left: 2px; }
    .gs-card__arrow { margin-left: auto; color: var(--text-faint); flex: 0 0 auto; }
    .gs-card__head:hover .gs-card__arrow { color: var(--accent); }

    .gs-cmd {
      display: flex; align-items: center; gap: 10px; width: 100%; text-align: left;
      background: var(--bg); border: 1px solid var(--line); border-radius: var(--r-sm);
      padding: 9px 12px; cursor: pointer; color: var(--text-dim);
      transition: border-color .15s ease, color .15s ease;
    }
    .gs-cmd:hover { border-color: var(--line-2); color: var(--text); }
    .gs-cmd code { flex: 1 1 auto; font-size: 0.76rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .gs-cmd__i { flex: 0 0 auto; color: var(--text-faint); }
    .gs-cmd[data-done] { border-color: var(--accent); color: var(--accent-bright); }
    .gs-cmd[data-done] .gs-cmd__i { color: var(--accent-bright); }

    @media (max-width: 860px) { .gs-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 620px) {
      .gs-ext { flex-wrap: wrap; }
      .gs-ext__cta { width: 100%; justify-content: center; }
      .gs-grid { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    document.querySelectorAll<HTMLButtonElement>("[data-copy-cmd]").forEach((btn) => {
      btn.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(btn.dataset.copyCmd ?? "");
          btn.setAttribute("data-done", "");
          setTimeout(() => btn.removeAttribute("data-done"), 1400);
        } catch {}
      });
    });
  </script>
</section>
