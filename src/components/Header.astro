---
import { NAV, SITE, getStars, fmtStars } from "../data/site";
const stars = await getStars();
---

<header class="hdr">
  <div class="hdr__in">
    <a class="brand" href="/" aria-label="AI2Web home">
      <img src="/ai2web-logo-white.svg" alt="AI2Web" width="102" height="26" class="brand__logo" />
    </a>

    <!-- Header scanner: validate any site's AI readiness fast -->
    <form class="scan" role="search" data-scan action="/validator" method="get">
      <svg class="scan__i" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.6"/><path d="m20 20-3.2-3.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
      <input
        class="scan__in mono"
        type="text"
        name="url"
        inputmode="url"
        autocomplete="off"
        spellcheck="false"
        placeholder="Scan any site for AI readiness..."
        aria-label="Site URL to scan"
      />
      <button class="scan__go" type="submit" aria-label="Scan">
        <span class="scan__go-t">Scan</span>
      </button>
    </form>

    <nav class="nav" aria-label="Primary">
      {NAV.map((n) => <a href={n.href}>{n.label}</a>)}
    </nav>

    <div class="hdr__end">
      <a class="ghbtn" href={SITE.ghUrl} target="_blank" rel="noopener" aria-label="Star AI2Web on GitHub">
        <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>
        <svg class="ghbtn__star" viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27Z"/></svg>
        <span class="ghbtn__n mono">{fmtStars(stars)}</span>
      </a>
      <button class="icobtn" data-theme-toggle aria-label="Toggle color theme" type="button">
        <svg class="ico-sun" viewBox="0 0 24 24" fill="none" width="17" height="17" aria-hidden="true"><circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="1.6"/><path d="M12 2.5v2M12 19.5v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M2.5 12h2M19.5 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
        <svg class="ico-moon" viewBox="0 0 24 24" fill="none" width="17" height="17" aria-hidden="true"><path d="M20 14.5A8 8 0 0 1 9.5 4a8 8 0 1 0 10.5 10.5Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
      </button>
      <button class="icobtn menu" data-menu-toggle aria-label="Menu" aria-expanded="false" type="button">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>

  <div class="drawer" data-drawer hidden>
    <form class="dscan" role="search" data-scan action="/validator" method="get">
      <svg class="dscan__i" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.6"/><path d="m20 20-3.2-3.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
      <input class="dscan__in mono" type="text" name="url" inputmode="url" autocomplete="off" spellcheck="false" placeholder="Scan a site for AI readiness..." aria-label="Site URL to scan" />
      <button class="dscan__go" type="submit">Scan</button>
    </form>
    <nav aria-label="Mobile">
      {NAV.map((n) => <a href={n.href}>{n.label}</a>)}
    </nav>
    <a class="ghbtn ghbtn--drawer" href={SITE.ghUrl} target="_blank" rel="noopener" aria-label="Star AI2Web on GitHub">
      <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>
      <svg class="ghbtn__star" viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27Z"/></svg>
      <span class="ghbtn__n mono">{fmtStars(stars)}</span>
      <span class="ghbtn__label">Star on GitHub</span>
    </a>
  </div>
</header>

<style>
  .hdr {
    position: sticky; top: 0; z-index: 50;
    background: color-mix(in oklab, var(--bg) 78%, transparent);
    backdrop-filter: saturate(140%) blur(14px);
    border-bottom: 1px solid var(--line);
  }
  .hdr__in {
    max-width: var(--maxw); margin: 0 auto;
    padding: 10px var(--pad);
    display: flex; align-items: center; gap: 14px;
  }
  .brand { flex: 0 0 auto; display: inline-flex; align-items: center; }
  .brand__logo { height: 24px; width: auto; display: block; filter: var(--logo-filter, none); }
  :root[data-theme="light"] .brand__logo { filter: invert(1); }

  /* Scanner */
  .scan {
    flex: 1 1 auto; min-width: 0; max-width: 420px;
    display: flex; align-items: center; gap: 8px;
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: var(--r-sm);
    padding: 5px 6px 5px 11px;
    transition: border-color .16s ease, box-shadow .16s ease;
  }
  .scan:focus-within { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }
  .scan__i { width: 15px; height: 15px; color: var(--text-faint); flex: 0 0 auto; }
  .scan__in {
    flex: 1 1 auto; min-width: 0;
    background: none; border: 0; color: var(--text);
    font-size: 0.85rem; letter-spacing: -0.01em;
  }
  .scan__in::placeholder { color: var(--text-faint); }
  .scan__in:focus { outline: none; }
  .scan__go {
    flex: 0 0 auto; border: 0; cursor: pointer;
    background: var(--accent); color: #06120a; font-weight: 600;
    font-size: 0.78rem; padding: 5px 11px; border-radius: 6px;
    transition: background .16s ease;
  }
  .scan__go:hover { background: var(--accent-bright); }

  .nav { display: flex; gap: 4px; flex: 0 0 auto; }
  .nav a {
    color: var(--text-dim); font-size: 0.9rem; padding: 7px 10px; border-radius: 6px;
    transition: color .15s ease, background .15s ease;
  }
  .nav a:hover { color: var(--text); background: var(--surface-2); }

  .hdr__end { display: flex; align-items: center; gap: 8px; flex: 0 0 auto; margin-left: auto; }
  .ghbtn {
    display: inline-flex; align-items: center; gap: 7px;
    border: 1px solid var(--line-2); border-radius: var(--r-sm);
    padding: 6px 11px; font-size: 0.86rem; color: var(--text);
    transition: border-color .15s ease, background .15s ease;
  }
  .ghbtn:hover { border-color: var(--text-faint); background: var(--surface-2); }
  .ghbtn__n { font-size: 0.82rem; color: var(--text-dim); font-variant-numeric: tabular-nums; }
  .ghbtn__star { color: currentColor; flex: 0 0 auto; }
  .ghbtn__label { display: none; }

  .icobtn {
    display: inline-grid; place-items: center;
    width: 34px; height: 34px; border-radius: var(--r-sm);
    background: var(--surface-2); border: 1px solid var(--line);
    color: var(--text-dim); cursor: pointer;
    transition: color .15s ease, border-color .15s ease;
  }
  .icobtn:hover { color: var(--text); border-color: var(--line-2); }
  .menu { display: none; }
  :root[data-theme="dark"] .ico-sun { display: none; }
  :root[data-theme="light"] .ico-moon { display: none; }

  .drawer { display: none; border-top: 1px solid var(--line); background: var(--bg-1); padding: var(--pad); }
  .drawer[hidden] { display: none; }
  .drawer nav { display: grid; gap: 2px; }
  .drawer a { padding: 12px 8px; color: var(--text-dim); border-radius: 8px; font-size: 1rem; }
  .drawer a:hover { color: var(--text); background: var(--surface-2); }
  /* GitHub pill in the drawer: bordered + starred, matching the desktop button. */
  .drawer .ghbtn { display: inline-flex; width: fit-content; margin-top: 14px; padding: 9px 14px; color: var(--text); font-size: 0.92rem; }
  .drawer .ghbtn .ghbtn__label { display: inline; }
  .drawer .ghbtn:hover { background: var(--surface-2); }

  /* Drawer scanner: only on true mobile, where the header scanner is hidden. */
  .dscan { display: none; align-items: center; gap: 8px; margin-bottom: 14px; background: var(--surface-2); border: 1px solid var(--line-2); border-radius: var(--r-sm); padding: 6px 6px 6px 12px; }
  .dscan:focus-within { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }
  .dscan__i { width: 16px; height: 16px; color: var(--text-faint); flex: 0 0 auto; }
  .dscan__in { flex: 1 1 auto; min-width: 0; background: none; border: 0; color: var(--text); font-size: 0.9rem; padding: 9px 0; }
  .dscan__in:focus { outline: none; }
  .dscan__in::placeholder { color: var(--text-faint); }
  .dscan__go { flex: 0 0 auto; border: 0; cursor: pointer; background: var(--accent); color: #06120a; font-weight: 600; font-size: 0.82rem; padding: 9px 15px; border-radius: 6px; }
  .dscan__go:hover { background: var(--accent-bright); }

  /* Tablet and down: nav collapses into the drawer. */
  @media (max-width: 1040px) {
    .nav { display: none; }
    .menu { display: inline-grid; }
    .drawer[data-open] { display: block; }
  }
  /* Mobile: the header scanner moves into the drawer so it is usable. */
  @media (max-width: 720px) {
    .scan { display: none; }
    .ghbtn { display: none; }
    .dscan { display: flex; }
  }
</style>

<script>
  // Mobile drawer
  const mt = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const drawer = document.querySelector<HTMLElement>("[data-drawer]");
  mt?.addEventListener("click", () => {
    const open = drawer?.hasAttribute("data-open");
    if (open) { drawer?.removeAttribute("data-open"); drawer?.setAttribute("hidden", ""); }
    else { drawer?.setAttribute("data-open", ""); drawer?.removeAttribute("hidden"); }
    mt.setAttribute("aria-expanded", String(!open));
  });

  // Normalize the scanned URL before handing it to the validator page. Applies to every
  // scanner on the page: header, hero and the mobile drawer.
  document.querySelectorAll<HTMLFormElement>("[data-scan]").forEach((form) => {
    form.addEventListener("submit", () => {
      const input = form.querySelector<HTMLInputElement>('input[name="url"]');
      if (input && input.value && !/^https?:\/\//i.test(input.value.trim())) {
        input.value = "https://" + input.value.trim();
      }
    });
  });
</script>
