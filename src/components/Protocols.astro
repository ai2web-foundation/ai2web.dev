---
const protocols = [
  { name: "MCP", d: "Tools & actions for assistants", tag: "actions" },
  { name: "ACP", d: "Agentic commerce & checkout", tag: "commerce" },
  { name: "AP2", d: "Agent payments & signed mandates", tag: "payments" },
  { name: "NLWeb", d: "Natural-language site queries", tag: "conversational" },
  { name: "REST + feeds", d: "Content & catalog, cache-friendly", tag: "content" },
  { name: "GraphQL", d: "Typed queries over capabilities", tag: "query" },
  { name: "OpenAPI", d: "A described, discoverable API", tag: "describe" },
  { name: "Webhooks", d: "Subscribable events, push or poll", tag: "events" },
];
---

<section class="section" id="protocols">
  <div class="wrap">
    <span class="eyebrow reveal" data-n="03">Transports</span>
    <div class="pr-head">
      <h2 class="h2 reveal" data-d="1">One manifest.<br /><span class="dim">Every protocol.</span></h2>
      <p class="lede reveal" data-d="2">
        AI2Web sits above the transports and negotiates which to use, so any protocol's
        success is a tailwind, not a rewrite. Add one and the rest come for free.
      </p>
    </div>

    <div class="pr-flow reveal" data-d="1">
      <div class="pr-source card">
        <span class="pr-source__tag mono">source of truth</span>
        <code class="pr-source__url mono">/ai2w</code>
        <span class="dim pr-source__d">Your capability manifest</span>
      </div>
      <div class="pr-arrow" aria-hidden="true">
        <svg viewBox="0 0 60 24" fill="none"><path d="M2 12h52m0 0-8-7m8 7-8 7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span class="mono">projects to</span>
      </div>
      <div class="pr-grid">
        {protocols.map((p, i) => (
          <div class="pr-chip card reveal" data-d={String((i % 4) + 1)}>
            <div class="pr-chip__top">
              <span class="pr-chip__name mono">{p.name}</span>
              <span class="pr-chip__tag mono">{p.tag}</span>
            </div>
            <span class="dim pr-chip__d">{p.d}</span>
          </div>
        ))}
      </div>
    </div>

    <p class="pr-note dim reveal">
      Discovery stays neutral too: if a cross-vendor standard emerges, AI2Web is designed to be
      carried by it rather than compete. WebMCP is supported as an optional in-page adapter.
    </p>
  </div>

  <style>
    .pr-head { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(20px, 4vw, 56px); align-items: end; margin: 14px 0 44px; }
    @media (max-width: 760px) { .pr-head { grid-template-columns: 1fr; gap: 16px; } }

    .pr-flow { display: grid; grid-template-columns: 220px auto 1fr; gap: 22px; align-items: center; }
    .pr-source { padding: 22px; display: grid; gap: 8px; text-align: center; align-content: center; }
    .pr-source__tag { font-size: 0.66rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--text-faint); }
    .pr-source__url { font-size: 1.5rem; font-weight: 600; color: var(--accent-bright); }
    .pr-source__d { font-size: 0.85rem; }
    .pr-arrow { display: grid; place-items: center; gap: 8px; color: var(--text-faint); }
    .pr-arrow svg { width: 60px; height: 24px; }
    .pr-arrow span { font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; }

    .pr-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
    .pr-chip { padding: 16px 18px; display: grid; gap: 8px; transition: border-color .2s ease, transform .2s ease; }
    .pr-chip:hover { border-color: var(--line-2); transform: translateY(-2px); }
    .pr-chip__top { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
    .pr-chip__name { font-weight: 600; font-size: 0.98rem; color: var(--text); }
    .pr-chip__tag { font-size: 0.66rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); background: var(--accent-glow); padding: 2px 7px; border-radius: 5px; }
    .pr-chip__d { font-size: 0.85rem; }

    .pr-note { margin-top: 32px; font-size: 0.9rem; max-width: 70ch; }

    @media (max-width: 980px) {
      .pr-flow { grid-template-columns: 1fr; gap: 28px; }
      .pr-arrow { transform: rotate(90deg); margin: 10px 0; }
    }
    @media (max-width: 560px) { .pr-grid { grid-template-columns: 1fr; } }
  </style>
</section>
